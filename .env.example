# Romeo_PHD v7 — environment template.
#
# Copy this file to .env at the repo root before running
# `docker compose up` (or `docker compose -f docker-compose.dev.yml up`).
# Never commit the real .env — it is covered by .gitignore and
# .dockerignore.
#
# Every variable below is REQUIRED unless explicitly marked optional.

# -----------------------------------------------------------------------------
# LLM access
# -----------------------------------------------------------------------------

# Anthropic API key, used by lib/integrations-anthropic-ai.
# Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Database — Postgres + pgvector
# -----------------------------------------------------------------------------
#
# Per v7 decision (docs/v7-audit.md §6), v7 stays on Postgres and layers
# pgvector on top for future vector-search / RAG workloads. Migration to
# MongoDB Atlas is planned for after v7 and is NOT handled here.
#
# DATABASE_URL is consumed by:
#   - lib/db/src/index.ts (pg.Pool + drizzle)
#   - lib/db/drizzle.config.ts (drizzle-kit push)
#
# In docker-compose.yml the hostname must be `postgres` (the compose
# service name). For local non-Docker dev, point it at your own host.

DATABASE_URL=postgres://romeo:romeo@postgres:5432/romeo_phd

# Credentials used by the `postgres` service in docker-compose.yml to
# initialise the database on first boot. Must stay in sync with the
# user/password/db in DATABASE_URL above.
POSTGRES_USER=romeo
POSTGRES_PASSWORD=romeo
POSTGRES_DB=romeo_phd

# -----------------------------------------------------------------------------
# Service ports (host-side)
# -----------------------------------------------------------------------------

# Express api-server listens on 3001 inside its container; this maps it
# to the host. Change if 3001 is already taken on your machine.
API_PORT=3001

# nginx-served UI on the host. Prod-like compose exposes nginx on 8080
# to avoid colliding with common local services on 80.
UI_PORT=8080

# Postgres host port. Only needs to be reachable if you want to connect
# with psql / a GUI client from the host.
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Build-time (dev compose / vite)
# -----------------------------------------------------------------------------

# Vite dev server (docker-compose.dev.yml). Mirrors README's port 5173.
# Not used by the prod nginx image.
VITE_PORT=5173

# Vite `base` option. `/` means the UI is served from the domain root.
# Override if you front it with a path-prefixed reverse proxy.
BASE_PATH=/
