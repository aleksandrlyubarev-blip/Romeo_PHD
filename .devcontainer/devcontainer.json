{
  "name": "RomeoPHD v6.0",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-24-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/postgresql:1": {
      "version": "16"
    }
  },

  "forwardPorts": [3001, 5173],
  "portsAttributes": {
    "3001": { "label": "API Server", "onAutoForward": "notify" },
    "5173": { "label": "Frontend (UI)", "onAutoForward": "openBrowser" }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "ms-vscode.vscode-typescript-next"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "remoteEnv": {
    "DATABASE_URL": "postgresql://romeo:romeo@localhost:5432/romeophi",
    "PORT": "3001",
    "NODE_ENV": "development"
  }
}
